# ===========================================================================
# Variáveis de Ambiente — Virtual Medical Assistant
# ===========================================================================
# Copie este arquivo para .env e preencha com seus valores:
#   cp .env.example .env
# ===========================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medical_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Modelo Fine-Tuned
# ---------------------------------------------------------------------------
# Aceita path local OU repositório do Hugging Face Hub:
#   Local:  models/medical-assistant-final
#   Hub:    zagari/medical-assistant-mistral-7b-ft  (download automático)
FINE_TUNED_MODEL=zagari/medical-assistant-mistral-7b-ft

# ---------------------------------------------------------------------------
# Hugging Face Hub
# ---------------------------------------------------------------------------
# Token de acesso (obrigatório para upload, opcional para download de modelos públicos)
# Crie em: https://huggingface.co/settings/tokens (permissão "write")
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repositório no Hub para upload/download do modelo fine-tuned
# Formato: usuario/nome-do-modelo
# HF_HUB_REPO=seu-usuario/medical-assistant-mistral-7b-ft

# ---------------------------------------------------------------------------
# ChromaDB (RAG)
# ---------------------------------------------------------------------------
CHROMA_DB_PATH=./chroma_db
